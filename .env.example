# memovox optional configuration (all have sensible defaults; nothing is required)

# Where the knowledge store lives (default: ~/.memovox)
# MEMOVOX_STORE=~/knowledge

# Backend selection (default "auto" -> best installed, else free fallback)
# MEMOVOX_ASR_BACKEND=auto          # auto | whisper | captions | fake
# MEMOVOX_EMBED_BACKEND=auto        # auto | hashing | sentence-transformers
# MEMOVOX_NLI_BACKEND=auto          # auto | lexical | deberta-nli
# MEMOVOX_LLM_BACKEND=auto          # auto | ollama | none

# Entity linking is OFFLINE by default (slug-based, no network). Opt into the
# Wikidata linker (sends entity surface forms to wikidata.org) explicitly:
# MEMOVOX_ENTITY_LINK=wikidata      # default offline; "wikidata" enables egress

# Tunables
# MEMOVOX_EMBED_DIM=256
# MEMOVOX_ENTAILMENT_THRESHOLD=0.5
# MEMOVOX_TOP_K=8

# Local LLM (Ollama) — used only if MEMOVOX_LLM_BACKEND lets it; no API key needed
# OLLAMA_HOST=http://127.0.0.1:11434
# MEMOVOX_LLM_MODEL=llama3.1

# Optional Vosk model dir for the [vosk] ASR alternative
# VOSK_MODEL_PATH=~/.memovox/models/vosk-model-small-en-us-0.15
